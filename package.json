{
  "name": "lensprompt-recorder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:phone": "VITE_HTTPS=1 vite --host 0.0.0.0",
